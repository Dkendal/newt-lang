export type At(A, K)
    where
        A <: any,
        K <: Key
    as
        if A <: List then
            if number <: A['length'] then
                if K <: number | `${number}` then
                    A[never] | undefined
                else
                    undefined
                end
            else
                if K <: keyof A then
                    A[K]
                else
                    undefined
                end
            end
        else
            if unknown <: A then
                unknown
            else
                if K <: keyof A then
                    A[K]
                else
                    undefined
                end
            end
        end


export type Key as string | number | symbol

// type ReadonlyArray(T) as T[]

export type List(A)
    defaults
        A = any
    as
        ReadonlyArray(A)

// TODO allow for types in unittest blocks that aren't emitted
// TODO raise on unresolved types
// TODO include built-in types
type User as {
    info: {
        name: string,
        age: number,
        payment: {}
    },
    id: number
}

unittest "At(A, K)" do
    assert At(User, 'id') <: number
end
