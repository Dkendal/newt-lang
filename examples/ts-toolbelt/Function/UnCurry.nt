import { Curry } from "./Curry"

export type UnCurry(F)
    where F <: Curry(any)
    do
        if F <: Curry(?UF) then
            UF
        end
end

unittest "UnCurry(F)" do
    // TODO: evaluator cannot prove this yet (infer through a generic alias
    // application)
    assert UnCurry(Curry((a: string, b: number) => boolean)) == ((a: string, b: number) => boolean)
end
