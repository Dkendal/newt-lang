import { Key } from "../Any/Key"
import { Head } from "../List/Head"
import { List } from "../List/List"
import { Pop } from "../List/Pop"
import { Tail } from "../List/Tail"
import { Path } from "../Object/Path"
import { UnionOf } from "../Object/UnionOf"
import { Select } from "../Union/Select"
import { Join } from "../String/Join"
import { Split } from "../String/Split"

type Index do number | string end

type KeyToIndex(K, SP)
    where K <: Key, SP <: List(Index)
    do if number <: K then Head(SP) else K & Index end
end

type MetaPath(O, D, SP, P)
    defaults SP = [], P = []
    where D <: string, SP <: List(Index), P <: List(Index)
    do map K in keyof O do
        MetaPath(O[K], D, Tail(SP), [...P, KeyToIndex(K, SP)])
        | Join([...P, KeyToIndex(K, SP)], D)
    end
end

// `Exclude` is a TS lib global; newtype has no lib types, so a local
// distributive equivalent stands in.
type _Exclude(A, B) do if A <: B then never else A end end

// the next paths after property `K` are on sub objects
// O[K] === K | {x: '${K}.x' | {y: '${K}.x.y' ...}}
// So we access O[K] then we only keep the next paths
// by excluding `string` out of it, taking the union of
// what's left, and selecting the direct next paths.
type NextPath(OP) do Select(UnionOf(_Exclude(OP, string) & {}), string) end

// We go in the `MetaPath` of `O` to get the prop at `SP`
// So we query what is going the `NextPath` at `O[...SP]`
type ExecPath(A, SP, Delimiter)
    where SP <: List(Index), Delimiter <: string
    do NextPath(Path(MetaPath(A, Delimiter, SP), SP))
end

type HintPath(A, P, SP, Exec, D)
    where P <: string, SP <: List(Index), Exec <: string, D <: string
    do if [Exec] <: [never] then
        // if has not found paths, display previous paths
        ExecPath(A, Pop(SP), D)
    else
        // display current + next
        Exec | P
    end
end

type _AutoPath(A, P, D, SP)
    defaults SP = Split(P, D)
    where P <: string, D <: string, SP <: List(Index)
    do HintPath(A, P, SP, ExecPath(A, SP, D), D)
end

// Auto-complete, validate, and query the string path of an object `O`
export type AutoPath(O, P, D)
    defaults D = '.'
    where O <: any, P <: string, D <: string
    do _AutoPath(O, P, D)
end
