import { List } from "../List/List"

export type Function(P, R)
    defaults P = any, R = any
    where P <: List, R <: any
    do (...args: P) => R
end

unittest "Function(P, R)" do
    assert Function([string, number], boolean) <: (a: string, b: number) => boolean
    assert (a: string, b: number) => boolean <: Function([string, number], boolean)
    assert (name: string, age: number) => {} <: Function
end
