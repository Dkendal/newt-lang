// Describes function modes
// `sync` : Normal function
// `async`: Promised result
export type Mode do 'sync' | 'async' end

// Describes function parameter input
// `multi`: ( a, b, c ... n ) => X
// `list` : ([a, b, c ... n]) => X
export type Input do 'multi' | 'list' end

// Describes types that can be narrowed
export type Narrowable do
    string
    | number
    | bigint
    | boolean
end

unittest "_Internal" do
    assert 'sync' <: Mode
    assert 'list' <: Input
    assert not('maybe' <: Mode)
    assert 42 <: Narrowable
    assert not([] <: Narrowable)
end
