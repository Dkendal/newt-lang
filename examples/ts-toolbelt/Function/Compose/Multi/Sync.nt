import { Curry } from "../../Curry"
import { Function } from "../../Function"

// TODO: the original TS is an object type of ten generic call signatures
// (one overload per composition arity, 1-10), e.g. for arity 2:
//   <R0, R1, P extends any[]>(...fns: [
//       Function<[R0], R1> | Curry<Function<[R0], R1>>,
//       Function<P,    R0> | Curry<Function<P,    R0>>,
//   ]): Function<P, R1>
// newtype has no call-signature object types, overloads, or generic function
// types, so a single untyped signature is the closest expressible form.
export type ComposeMultiSync do
    (...fns: (Function | Curry(Function))[]) => Function
end
