import { Curry } from "../../Curry"
import { Function } from "../../Function"

// TODO: newtype cannot express object types with generic call signatures
// (function overloads). The original TS is an object type with ten generic
// call signatures, one per pipeline arity:
//
//   export type PipeMultiSync = {
//       <R0, P extends any[]>(...fns: [
//           Function<P, R0> | Curry<Function<P, R0>>,
//       ]): Function<P, R0>
//       <R0, R1, P extends any[]>(...fns: [
//           Function<P,    R0> | Curry<Function<P,    R0>>,
//           Function<[R0], R1> | Curry<Function<[R0], R1>>,
//       ]): Function<P, R1>
//       // ... and so on, up to R9
//   }
//
// Closest expressible form: a single non-generic signature taking the
// (possibly curried) functions as a non-empty rest parameter.
export type PipeMultiSync do (
    ...fns: [
        Function(any[], any) | Curry(Function(any[], any)),
        ...(Function(any[], any) | Curry(Function(any[], any)))[]
    ]
) => Function(any[], any)
end
