// Ported from ts-toolbelt sources/Number/Greater.ts

import { _Sub } from "./Sub"
import { _IsPositive } from "./IsPositive"
import { Iteration } from "../Iteration/Iteration"
import { IterationOf } from "../Iteration/IterationOf"

export type _Greater(N1, N2)
    where
        N1 <: Iteration,
        N2 <: Iteration
    do _IsPositive(_Sub(N1, N2))
end

// Check if a number is bigger than another one
export type Greater(N1, N2)
    where
        N1 <: number,
        N2 <: number
    do
        if N1 <: unknown then
            if N2 <: unknown then
                _Greater(IterationOf(N1), IterationOf(N2))
            end
        end
end

unittest "Greater(N1, N2)" do
    // TODO: evaluator cannot prove this yet (recursive alias evaluation and
    // template-literal interpolation inside IterationOf)
    assert Greater(7, 5) == 1
    // TODO: evaluator cannot prove this yet
    assert Greater(5, 5) == 0
    // TODO: evaluator cannot prove this yet
    assert Greater(5, 7) == 0
end
