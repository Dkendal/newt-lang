// Ported from ts-toolbelt sources/Number/GreaterEq.ts

import { Equals } from "../Any/Equals"
import { _Greater } from "./Greater"
import { Iteration } from "../Iteration/Iteration"
import { IterationOf } from "../Iteration/IterationOf"
import { Or } from "../Boolean/Or"

export type _GreaterEq(N1, N2)
    where
        N1 <: Iteration,
        N2 <: Iteration
    as Or(Equals(N1, N2), _Greater(N1, N2))

// Check if a number is greater or equal to another one
export type GreaterEq(N1, N2)
    where
        N1 <: number,
        N2 <: number
    as
        if N1 <: unknown then
            if N2 <: unknown then
                _GreaterEq(IterationOf(N1), IterationOf(N2))
            end
        end

unittest "GreaterEq(N1, N2)" do
    // TODO: evaluator cannot prove this yet (recursive alias evaluation and
    // template-literal interpolation inside IterationOf)
    assert GreaterEq(7, 5) == 1
    // TODO: evaluator cannot prove this yet
    assert GreaterEq(5, 5) == 1
    // TODO: evaluator cannot prove this yet
    assert GreaterEq(5, 7) == 0
end
