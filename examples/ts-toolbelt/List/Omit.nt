import { _Omit as _OOmit } from "../Object/Omit"
import { _ListOf } from "../Object/ListOf"
import { Key } from "./_Internal"
import { List } from "./List"
import { ObjectOf } from "./ObjectOf"

export type _Omit(L, K)
    where
        L <: List,
        K <: Key
    do
        _ListOf(_OOmit(ObjectOf(L), `${K & number}` | K))
end

export type Omit(L, K)
    where
        L <: List,
        K <: Key
    do
        if L <: unknown then
            _Omit(L, K)
        end
end

unittest "Omit(L, K)" do
    // TODO: evaluator cannot prove this yet
    assert Omit([1, 2, 3], '0') == [2, 3]
end
