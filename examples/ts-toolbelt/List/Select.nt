import { Match } from "../Any/_Internal"
import { Select as OSelect } from "../Object/Select"
import { ListOf } from "../Object/ListOf"
import { ObjectOf } from "./ObjectOf"
import { List } from "./List"

// Extract the entries of `L` that match `M`
export type Select(L, M, match)
    defaults match = 'default'
    where
        L <: List,
        M <: any,
        match <: Match
    as ListOf(OSelect(ObjectOf(L), M, match))

unittest "Select(L, M)" do
    // TODO: evaluator cannot prove this yet
    assert Select([1, 'a', 2], number) == [1, 2]
end
