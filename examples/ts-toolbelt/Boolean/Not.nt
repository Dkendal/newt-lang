import { Boolean } from "./_Internal"

// TODO: original TS uses a numeric-keyed object lookup table
// ({0: 1, 1: 0}[B]); numeric property names are not supported,
// so an equivalent tuple lookup is used.
export type Not(B)
    where
        B <: Boolean
    as
        [1, 0][B]

unittest "Not(B)" do
    assert Not(1) == 0
    assert Not(0) == 1
end
