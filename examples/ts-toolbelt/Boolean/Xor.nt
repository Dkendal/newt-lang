import { Boolean } from "./_Internal"

// TODO: original TS uses a numeric-keyed object lookup table
// ({0: {0: 0, 1: 1}, 1: {0: 1, 1: 0}}[B1][B2]); numeric property
// names are not supported, so an equivalent tuple lookup is used.
export type Xor(B1, B2)
    where
        B1 <: Boolean,
        B2 <: Boolean
    as
        [
            [0, 1],
            [1, 0]
        ][B1][B2]

unittest "Xor(B1, B2)" do
    assert Xor(1, 1) == 0
    assert Xor(0, 1) == 1
    assert Xor(Boolean, 1) == Boolean
end
