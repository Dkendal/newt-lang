import { Key } from "../Any/Key"

type __Pick(O, K)
    where
        O <: object,
        K <: keyof O
    do
        (map P in K do
            O[P]
        end) & {}
end

export type _Pick(O, K)
    where
        O <: object,
        K <: Key
    do __Pick(O, keyof O & K)
end

// Extract out of `O` the fields of key `K`
export type Pick(O, K)
    where
        O <: object,
        K <: Key
    do
        if O <: unknown then
            _Pick(O, K)
        end
end

// TODO allow for types in unittest blocks that aren't emitted
type User do { name: string, age: number } end

unittest "Pick(O, K)" do
    // TODO: evaluator cannot prove these yet (it does not reduce the
    // `keyof O & K` intersection inside the mapped type)
    assert Pick(User, 'name') == { name: string }
    assert Pick(User, 'name' | 'zzz') == { name: string }
end
