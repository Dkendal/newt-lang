import { Nullable as UNullable } from "../Union/Nullable"
import { Depth } from "./_Internal"
import { _Pick } from "./Pick"
import { Key } from "../Any/Key"
import { PatchFlat } from "./Patch"

export type NullableFlat(O) do
    (map K in keyof O do UNullable(O[K]) end) & {}
end

export type NullableDeep(O) do
    map K in keyof O do
        NullableDeep(UNullable(O[K]))
    end
end

type NullablePart(O, depth)
    where
        O <: object,
        depth <: Depth
    do
        match depth do
            'flat' -> NullableFlat(O),
            'deep' -> NullableDeep(O)
        end
end

export type _Nullable(O, K, depth)
    where
        O <: object,
        K <: Key,
        depth <: Depth
    do
        PatchFlat(NullablePart(_Pick(O, K), depth), O)
end

// Make some fields of `O` nullable (deeply or not)
export type Nullable(O, K, depth)
    defaults K = Key, depth = 'flat'
    where
        O <: object,
        K <: Key,
        depth <: Depth
    do
        if O <: unknown then
            _Nullable(O, K, depth)
        end
end

unittest "Nullable(O, K, depth)" do
    // TODO: evaluator cannot prove this yet (depends on ../Union/Nullable,
    // ./Pick and ./Patch)
    assert Nullable({a: 1, b: 2}, 'a') == {a: 1 | null | undefined, b: 2}
end
