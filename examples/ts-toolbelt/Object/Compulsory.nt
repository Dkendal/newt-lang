import { _Pick } from "./Pick"
import { Depth } from "./_Internal"
import { Key } from "../Any/Key"
import { NonNullable } from "../Union/NonNullable"
import { PatchFlat } from "./Patch"
import { BuiltIn } from "../Misc/BuiltIn"

export type CompulsoryFlat(O)
    do
        map -optional K in keyof O do NonNullable(O[K]) end & {}
end

export type CompulsoryDeep(O)
    do
        map -optional K in keyof O do
            if O[K] <: BuiltIn then
                O[K]
            else
                CompulsoryDeep(NonNullable(O[K]))
            end
        end
end

export type CompulsoryPart(O, depth)
    where
        O <: object,
        depth <: Depth
    do
        match depth do
            'flat' -> CompulsoryFlat(O),
            'deep' -> CompulsoryDeep(O)
        end
end

export type _Compulsory(O, K, depth)
    where
        O <: object,
        K <: Key,
        depth <: Depth
    do
        PatchFlat(CompulsoryPart(_Pick(O, K), depth), O)
end

// Make that `O`'s fields cannot be nullable or optional (it's like
// `Required` & `NonNullable` at once).
export type Compulsory(O, K, depth)
    defaults K = Key, depth = 'flat'
    where
        O <: object,
        K <: Key,
        depth <: Depth
    do
        if O <: unknown then
            _Compulsory(O, K, depth)
        end
end

unittest "Compulsory(O)" do
    // TODO: evaluator cannot prove this yet (depends on ./Pick, ./Patch,
    // ../Union/NonNullable which may not resolve)
    assert Compulsory({a: 1 | undefined, b: 2 | null}) <: {a: 1, b: 2}
end
