import { At } from "../Any/At"
import { Key } from "../Any/Key"

// Make the fields of `O` union the ones of `O1`
export type Unionize(O, O1, K)
    defaults K = Key
    where
        O <: object,
        O1 <: object,
        K <: Key
    as
        map P in keyof O do
            if P <: K then
                O[P] | At(O1, P)
            else
                O[P]
            end
        end & {}

unittest "Unionize(O, O1, K)" do
    assert Unionize({a: 1, b: 2}, {a: string, b: boolean}, 'a') == {a: 1 | string, b: 2}
    assert Unionize({a: 1, b: 2}, {a: string, b: boolean}) == {a: 1 | string, b: 2 | boolean}
end
