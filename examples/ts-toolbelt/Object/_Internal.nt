// Describes the permissions/modifiers fields can have
// `R`: readonly
// `W`: writable
// `!`: required
// `?`: optional
export type Modx do ['?' | '!', 'W' | 'R'] end

// Describes the depth strategy when modifying types
export type Depth do 'flat' | 'deep' end

// Describes the merging strategy
// `0`: lodash style. Preserves lists, and completes when undefined types
// `1`: ramda style. Destroys lists, does not complete if undefined types
// `2`: lodash style. Lists are narrowed down, tuples are not preserved
export type MergeStyle do 0 | 1 | 2 end

// Make an object properties (all) `never`. We use this to intersect `object`s
// and preserve the combine modifiers like `+readonly` and `?optional`.
export type Anyfy(O)
    where
        O <: object
    do
        map K in keyof O do any end
end

unittest "_Internal" do
    assert 'flat' <: Depth
    assert 'deep' <: Depth
    assert not('shallow' <: Depth)
    assert Anyfy({a: 1, b: string}) == {a: any, b: any}
end
