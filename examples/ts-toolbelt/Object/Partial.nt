import { OptionalPart } from "./Optional"
import { Depth } from "./_Internal"

// Make all fields of `O` optional (deeply or not)
export type Partial(O, depth)
    defaults depth = 'flat'
    where
        O <: object,
        depth <: Depth
    do OptionalPart(O, depth)
end

// TODO allow for types in unittest blocks that aren't emitted
type L do {a: {b: {c: 2}}, b: 1} end

unittest "Partial(O, depth)" do
    assert Partial(L) == {a?: {b: {c: 2}}, b?: 1}
    // TODO: evaluator cannot prove this yet (deep recursion through
    // OptionalPart / _Internal Depth machinery)
    assert Partial(L, 'deep') == {a?: {b?: {c?: 2}}, b?: 1}
end
