import { Match } from "../Any/_Internal"
import { Is } from "../Any/Is"

export type _Replace(O, M, A, match)
    where
        O <: object,
        M <: any,
        A <: any,
        match <: Match
    do
        map K in keyof O do
            match Is(M, O[K], match) do
                1 -> A,
                0 -> O[K]
            end
        end & {}
end

// Update with `A` the fields of `O` that match `M`
export type Replace(O, M, A, match)
    defaults match = 'default'
    where
        O <: object,
        M <: any,
        A <: any,
        match <: Match
    do
        if O <: unknown then
            _Replace(O, M, A, match)
        end
end

unittest "Replace(O, M, A, match)" do
    assert Replace({a: 1, b: string}, string, boolean) == {a: 1, b: boolean}
    assert Replace({a: 1, b: string}, number, boolean, 'extends->') == {a: 1, b: string}
end
