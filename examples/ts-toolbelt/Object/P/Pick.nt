import { Key } from "../../Any/Key"
import { _Pick as _OPick } from "../Pick"
import { List } from "../../List/List"
import { Tail } from "../../List/Tail"
import { BuiltIn } from "../../Misc/BuiltIn"
import { _ListOf } from "../ListOf"

type PickAt(O, Path)
    where
        Path <: List(Key)
    do cond do
        [] <: Path -> O,
        O <: BuiltIn -> O,
        O <: List ->
            _ListOf(map K in keyof _OPick(O, Path[0]) do
                PickAt(O[K], Tail(Path))
            end),
        O <: object ->
            map K in keyof _OPick(O, Path[0]) do
                PickAt(O[K], Tail(Path))
            end,
        else -> O
    end
end

// Extract out of `O` the fields at `Path`
export type Pick(O, Path)
    where
        O <: object,
        Path <: List(Key)
    do
        if Path <: unknown then
            PickAt(O, Path)
        end
end

// TODO allow for types in unittest blocks that aren't emitted
type User do {info: {name: string, age: number}, id: number} end

unittest "Pick(O, Path)" do
    // TODO: evaluator cannot prove this yet (depends on ../Pick and
    // recursive PickAt)
    assert Pick(User, ['info', 'name']) == {info: {name: string}}
end
