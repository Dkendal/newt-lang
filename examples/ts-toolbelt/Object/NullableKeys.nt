export type _NullableKeys(O)
    where
        O <: object
    do
        (map -optional K in keyof O do
            if [O[K] & (undefined | null)] <: [never] then
                never
            else
                K
            end
        end)[keyof O]
end

// Get the keys of `O` that are nullable
// (needs `--strictNullChecks` enabled)
export type NullableKeys(O)
    where
        O <: object
    do
        if O <: unknown then
            _NullableKeys(O)
        end
end

unittest "NullableKeys(O)" do
    // TODO: evaluator cannot prove this yet (mapped type with conditional
    // body indexed by `[keyof O]`)
    assert NullableKeys({a: 1, b: 2 | undefined, c: 3 | null}) == 'b' | 'c'
    // TODO: evaluator cannot prove this yet (same keys idiom)
    assert NullableKeys({a: 1}) == never
end
