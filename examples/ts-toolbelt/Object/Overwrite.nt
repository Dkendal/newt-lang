// Update the fields of `O` with the ones of `O1`
// (only the existing fields will be updated)
export type Overwrite(O, O1)
    where
        O <: object,
        O1 <: object
    as
        (map K in keyof O do
            if K <: keyof O1 then
                O1[K]
            else
                O[K]
            end
        end) & {}

unittest "Overwrite(O, O1)" do
    assert Overwrite({a: 1, b: 2}, {b: 3, c: 4}) == {a: 1, b: 3}
    assert Overwrite({a: 1}, {b: 2}) == {a: 1}
end
