import { Match } from "../Any/_Internal"
import { Is } from "../Any/Is"
import { At } from "../Any/At"
import { Key } from "../Any/Key"

// Check whether `O` has a field of key `K` that matches `M`
export type Has(O, K, M, match)
    defaults M = any, match = 'default'
    where
        O <: object,
        K <: Key,
        M <: any,
        match <: Match
    do
        Is(At(O, K), M, match)
end

unittest "Has(O, K, M, match)" do
    assert Has({a: 1, b: string}, 'a', number) == 1
    assert Has({a: 1, b: string}, 'b', number) == 0
    assert Has({a: 1, b: string}, 'z', number) == 0
end
