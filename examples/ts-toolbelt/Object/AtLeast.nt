import { _Omit } from "./Omit"
import { _Pick } from "./Pick"
import { Key } from "../Any/Key"
import { Keys } from "../Any/Keys"
import { RequiredFlat } from "./Required"
import { Extends } from "../Any/Extends"
import { ComputeRaw } from "../Any/Compute"
import { OptionalFlat } from "./Optional"

type RequiredIfKeys(O, K)
    where
        O <: object,
        K <: Key
    as
        if Extends(keyof O & K, K) <: 1 then
            RequiredFlat(O)
        else
            O
        end

type __AtLeast(O, K)
    where
        O <: object,
        K <: Key
    as
        // if we can operate on it, take entry & make rest optional
        if K <: keyof O then
            _Pick(O, K) & OptionalFlat(O)
        else
            O
        end

type _AtLeast(O, K)
    where
        O <: object,
        K <: Key
    as
        ComputeRaw(__AtLeast(RequiredIfKeys(O, K), K))

// Make that at least one of the keys `K` are required in `O` at a time.
export type AtLeast(O, K)
    defaults K = Keys(O)
    where
        O <: object,
        K <: Key
    as
        if O <: unknown then
            _AtLeast(O, K)
        end

unittest "AtLeast(O, K)" do
    // TODO: evaluator cannot prove this yet (depends on ./Pick, ./Required,
    // ./Optional which may not resolve)
    assert AtLeast({a: 1, b: 2}, 'a') <: {a: 1}
end
