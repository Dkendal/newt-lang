import { Exclude } from "./Exclude"

// Remove `undefined` & `null` out of `U`
export type NonNullable(U)
    where
        U <: any
    do
        Exclude(U, undefined | null)
end

unittest "NonNullable(U)" do
    assert NonNullable(string | undefined | null) == string
    assert NonNullable(string) == string
end
