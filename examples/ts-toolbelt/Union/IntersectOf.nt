// Credit https://stackoverflow.com/a/50375286/3570903

// Transform a [[Union]] to an **intersection**
export type IntersectOf(U)
    where
        U <: any
    as
        // Distribute U into a union of function types, then infer the single
        // (intersected) parameter back out.
        let fns = if U <: unknown then (k: U) => void end in
        if fns <: (k: ?I) => void then
            I
        end

unittest "IntersectOf(U)" do
    // TODO: evaluator cannot prove this yet (contravariant infer over a
    // distributed union of function types)
    assert IntersectOf({a: 1} | {b: 2}) == {a: 1} & {b: 2}
end
