import { Is } from "../Any/Is"
import { Match } from "../Any/_Internal"

// Replace `M` with `A` in `U`
export type Replace(U, M, A, match)
    defaults match = 'default'
    where
        U <: any,
        M <: any,
        A <: any,
        match <: Match
    do
        // TS uses a `{1: A, 0: U}[Is<U, M, match>]` lookup here; numeric
        // property names are not supported, so an equivalent tuple lookup is
        // used.
        if U <: unknown then
            [U, A][Is(U, M, match)]
        end
end

unittest "Replace(U, M, A, match)" do
    // TODO: evaluator cannot prove this yet (distribution over the union and
    // tuple lookup indexed by the result of Is)
    assert Replace('a' | 'b', 'a', 1) == 1 | 'b'
    // TODO: evaluator cannot prove this yet (same gap)
    assert Replace('a' | 'b', 'z', 1) == 'a' | 'b'
end
