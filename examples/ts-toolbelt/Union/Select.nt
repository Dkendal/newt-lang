import { Is } from "../Any/Is"
import { Match } from "../Any/_Internal"

// Extract the part of `U` that matches `M`
export type Select(U, M, match)
    defaults match = 'default'
    where
        U <: any,
        M <: any,
        match <: Match
    do
        // TS uses a `{1: U & M, 0: never}[Is<U, M, match>]` lookup here;
        // numeric property names are not supported, so an equivalent tuple
        // lookup is used.
        if U <: unknown then
            [never, U & M][Is(U, M, match)]
        end
end

unittest "Select(U, M, match)" do
    // TODO: evaluator cannot prove this yet (distribution over the union and
    // tuple lookup indexed by the result of Is)
    assert Select('a' | 'b' | 1, string) == 'a' | 'b'
    // TODO: evaluator cannot prove this yet (same gap)
    assert Select('a' | 'b' | 1, number) == 1
end
