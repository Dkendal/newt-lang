// All primitive types
export type Primitive do
    boolean
    | string
    | number
    | bigint
    | symbol
    | undefined
    | null
end

unittest "Primitive" do
    assert true <: Primitive
    assert 'hello' <: Primitive
    assert 42 <: Primitive
    assert undefined <: Primitive
    assert null <: Primitive
    assert not({} <: Primitive)
end
