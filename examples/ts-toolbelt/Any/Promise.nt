// An asynchronous operation like the original `Promise` type, but this one
// prevents promises from being wrapped within more promises (not possible).
export type Promise(A)
    where
        A <: any
    do
        globalThis.Promise(
            if A <: globalThis.Promise(?X) then X else A end
        )
end

unittest "Promise(A)" do
    // TODO: evaluator cannot prove this yet (`globalThis.Promise` is an
    // unresolvable reference, so the claim is indeterminate)
    assert Promise(Promise(number)) == Promise(number)
end
