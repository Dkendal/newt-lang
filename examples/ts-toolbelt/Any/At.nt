import { Key } from "./Key"
import { List } from "../List/List"

export type At(A, K)
    where
        A <: any,
        K <: Key
    do
        let value = A[K] in
        let keys = keyof A in
        if A <: List then
            if number <: A['length'] then
                if K <: number | `${number}` then
                    A[never] | undefined
                else
                    undefined
                end
            else
                if K <: keys then
                    value
                else
                    undefined
                end
            end
        else
            cond do
                unknown <: A -> unknown,
                K <: keys -> value,
                else -> undefined
            end
        end
end

// TODO allow for types in unittest blocks that aren't emitted
type User do {
    info: {
        name: string,
        age: number,
        payment: {}
    },
    id: number
}
end

unittest "At(A, K)" do
    assert At(User, 'id') <: number
end
