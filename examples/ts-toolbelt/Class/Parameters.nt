import { Class } from "./Class"

export type Parameters(C)
    where
        C <: Class
    do
        if C <: Class(?P, any) then
            P
        end
end

// TODO allow for types in unittest blocks that aren't emitted
type User do Class([string, string], { firstname: string, lastname: string }) end

unittest "Parameters(C)" do
    assert Parameters(User) == [string, string]
end
