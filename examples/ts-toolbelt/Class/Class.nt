import { List } from "../List/List"

// TS original: { new (...args: P): R } — a construct signature; the bare
// constructor type `new (...args: P) => R` is structurally equivalent.
export type Class(P, R)
    defaults
        P = any[],
        R = object
    where
        P <: List,
        R <: object
    do new (...args: P) => R
end

// TODO allow for types in unittest blocks that aren't emitted
type Test0 do Class([string, number], { a: string, b: number }) end

unittest "Class(P, R)" do
    assert Test0 <: Class
    assert Test0 == Class([string, number], { a: string, b: number })
end
