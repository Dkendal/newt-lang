import { Split } from "./Split"
import { Length as LLength } from "../List/Length"

// Get the length of a `string`
export type Length(S)
    where S <: string
    do LLength(Split(S, ''))
end

unittest "Length(S)" do
    // TODO: evaluator cannot prove this yet
    assert Length('hello') == 5
    // TODO: evaluator cannot prove this yet
    assert Length('') == 0
end
