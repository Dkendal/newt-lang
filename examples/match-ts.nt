unique symbol __kind__
unique symbol __capture__

type True do 1 end

type SymToStringTag do Symbol.toStringTag end

export type BuiltIn do
    Function
    | Error
    | Date
    | {readonly [Symbol.toStringTag]: string}
    | RegExp
    | Generator
end

type Primitive do
  boolean
  | string
  | number
  | bigint
  | symbol
  | undefined
  | null
end

type ExtractSubcapture(T) do
  match T do
    Primitive | BuiltIn -> never,
    object -> T[ Exclude(keyof(T), keyof([]) | keyof({})) ],
  end
end

type PartialAssignment(K, V) do
  cond do
    V <: never -> never,
    K <: string -> map k in K do V end,
    else -> never
  end
end

type EmptyToNever(T) do
  if {} <: T then
    never
  else
    T
  end
end

// `Kind` is `typeof any_ | typeof rest_ | …` in match-ts; each `X_` const is a
// string literal (`any_ = 'any'`), so the union is exactly these literals.
export type Kind do
  'any'
  | 'rest'
  | 'string'
  | 'number'
  | 'boolean'
  | 'function'
  | 'symbol'
  | 'bigint'
  | 'object'
end

export interface Hole(Type, Label)
defaults
  Type = any,
  Label = any
{
  T: Type,
  readonly [__kind__]: Label
}

// The per-type hole singletons and the `__` wildcard map (match-ts `index.ts`).
interface __any extends Hole(any, 'any') {}
export interface __string extends Hole(string, 'string') {}
export interface __number extends Hole(number, 'number') {}
export interface __boolean extends Hole(boolean, 'boolean') {}
export interface __symbol extends Hole(symbol, 'symbol') {}
export interface __bigint extends Hole(bigint, 'bigint') {}
export interface __object extends Hole(Object, 'object') {}
export interface __function extends Hole(Function, 'function') {}
export interface __rest extends Hole(any[], 'rest') {}

export interface __ extends Hole(any, 'any') {
  string: __string,
  number: __number,
  boolean: __boolean,
  // There is something weird going on where including this causes
  // RecursiveCollect to think that it has a circular reference
  object: __object,
  function: __function,
  symbol: __symbol,
  bigint: __bigint,
  any: __any,
  rest: __rest,
  tail: __rest,
  tl: __rest,
}

export type HoleInnerType(T) do
  if T <: Hole(?U) then
    U
  else
    T
  end
end

export interface Capture(Name, Pattern)
defaults
  Name = any,
  Pattern = any,
where
  Name <: String,
{
  readonly [__capture__]: Name,
  readonly pattern: Pattern,
}

type CapturePattern(T) do
  if T <: Capture(any, ?Pattern) then
    Pattern
  else
    T
  end
end

type RecursiveExpandCapture(T) do
  if T == any then
    T
  else
    if T <: Hole | Capture then
      ExpandCapture(T)
    else
      if T <: Record(string, any) then
        map K in keyof(T) do
          ExpandCapture(T[K])
        end
      else
        never
      end
    end
  end
end

export type ExpandCapture(T) do
  T
  |> HoleInnerType()
  |> CapturePattern()
  |> RecursiveExpandCapture()
end

type NeverToEmpty(T) do
  if [T] <: [never] then
    {}
  else
    T
  end
end

type Explode(T) do T[keyof(T)] end

export type RecursiveCollect(Node) do
  Node
  |> DoRecursiveCollect()
  |> NeverToEmpty()
end

type IsLeafNode(T) do
  cond do
    not(T <: Record(string, any)) -> true,
    T <: Hole -> true,
    T == any -> true,
    else -> false,
  end
end


type WalkChildren(Node) do
  map Key in keyof(Node) do
    DoRecursiveCollect(Node[Key])
  end
  |> Explode()
end

type DoRecursiveCollect(Node) do
  if IsLeafNode(Node) <: True then
    never
  else
    if Node <: Capture(any, ?P) then
      Node | DoRecursiveCollect(P)
    else
      WalkChildren(Node)
    end
  end
end

type UnionizeCapture(T) do
  if T <: Capture(?K, ?V) then
    if K <: string then
      map k in K do
        V
      end
    end
  end
end

export type CaptureToEntry(T) do
  T
  |> UnionizeCapture()
  |> Union::Merge()
end

export type VariableCapture(T) do
  T
  |> RecursiveCollect()
  |> CaptureToEntry()
  |> ExpandCapture()
end

export type PatternHandler(Pattern) do
  (VariableCapture(Pattern)) => unknown
end

type IsTopType(T) do
  cond do
      T == unknown -> true,
      T == object -> true,
      T == Object -> true,
      T == any -> true
  end
end


export type UnifyAll(Value, Pattern) do
  cond do
    IsTopType(Value) <: True ->
      VariableCapture(Pattern),

    Overlapping(Value, ExpandCapture(Pattern)) <: {} ->
      DoUnifyAll(Value, Pattern)
  end
end

export type DoUnifyAll(Value, Pattern) do
  cond do
    Pattern <: Capture(?VarName, ?Child) ->
      PartialAssignment(VarName, Overlapping(Value, ExpandCapture(Child)))
      | UnifyAll(Value, Child),

    Overlapping(Value, ExpandCapture(Pattern)) <: object ->
      ExtractSubcapture(
        map K in keyof(Value) do
          if K <: keyof(Pattern) then
            UnifyAll(Value[K], Pattern[K])
          else
            never
          end
        end
      )
  end
end

export type ShouldUnifyAll(Value, Pattern) do 
  if not(
    (Pattern == any and Value == any) or
    ((Pattern <: Primitive) and (Value <: Primitive))
  )
  then true
  else false
  end
end


export type CaseParameters(Value, Pattern) do
  UnifyAll(Value, Pattern)
  |> Union::Merge()
  |> EmptyToNever()
end

export type Overlapping(A, B, Depth)
defaults
  Depth = I::IterationOf(0)
where
  Depth <: I::Iteration
do
  cond do
    A::Equals(A, any) <: True -> B,
    A <: B -> A,
    [A, B, keyof(A)] <: [any[], any[], any] | [object, object, keyof(B)] ->
      RejectMismatch(
        map Key in keyof(A) do
          if Key <: keyof(B) then
            Overlapping(A[Key], B[Key], I::Next(Depth))
          else
            A[Key]
          end
        end
      )
  end
end

export type RejectMismatch(T) do
  cond do
    {} <: T -> never,
    T <: AnyNever(A::Cast(T, object)) -> never,
    else -> T
  end
end

export type AnyNever(T)
where
  T <: object
do
  if keyof(T) <: ?S then
    if S <: any then
      map K in A::Cast(S, string | number | symbol) do
        never
      end
    else
      never
    end
  else
    never
  end
end
